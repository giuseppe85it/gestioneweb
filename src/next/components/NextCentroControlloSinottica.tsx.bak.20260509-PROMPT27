import { useMemo, useState } from "react";
import type {
  RefuelRow,
  RefuelSeedIndex,
} from "../types/centroControlloTypes";
import {
  detectRefuelAnomalies,
  formatMediaLitriKm,
} from "../NextCentroControlloParityPage";

type MaintenanceStatus = "SCADUTA" | "IN_SCADENZA" | "OK" | "SENZA_DATA";

type AnagraficaMezzo = {
  id: string;
  targa: string;
  categoria: string;
  tipo: "motrice" | "cisterna" | null;
  marca: string;
  modello: string;
  autistaNome: string | null;
  manutenzioneDataFineTimestamp: number | null;
};

type ManutenzioneRecord = {
  id: string;
  targa: string;
  data: string;
  descrizione: string;
};

type LavoroRow = {
  id: string;
  targa: string | null;
  urgenza: "alta" | "media" | "bassa" | null;
  eseguito: boolean;
};

type SegnalazioneAggRow = {
  id: string;
  targa: string;
  tipo: string;
  isNuova: boolean;
};

type ControlloAggRow = {
  id: string;
  targa: string;
  isKo: boolean;
};

type RichiestaAggRow = {
  id: string;
  targa: string;
  isNuova: boolean;
};

type Props = {
  mezzi: AnagraficaMezzo[];
  refuelRows: RefuelRow[];
  refuelSeedIndex: RefuelSeedIndex;
  manutenzioniStorico: ManutenzioneRecord[];
  lavoriAperti: LavoroRow[];
  segnalazioniAperte: SegnalazioneAggRow[];
  controlliKo: ControlloAggRow[];
  richiesteAperte: RichiestaAggRow[];
  onTargaClick: (targa: string) => void;
};

type SegnaleChip =
  | { kind: "lavori"; total: number; urgenti: number }
  | { kind: "segn-tipo"; tipo: "freni" | "gomme" | "elettrico" | "altro"; count: number; severita: "urg" | "warn" }
  | { kind: "controllo-ko"; count: number }
  | { kind: "richieste"; count: number };

type SinotticaRow = {
  targa: string;
  categoria: string;
  iconKind: "trattore" | "cisterna" | "rimorchio";
  autistaNome: string | null;
  contrattoStatus: MaintenanceStatus;
  contrattoDataFine: number | null;
  contrattoDaysToDeadline: number | null;
  meseManutCount: number;
  meseManutUltimaTs: number | null;
  meseManutTuttoStoricoTs: number | null;
  kmL30gg: number | null;
  deltaKmLFlotta: number | null;
  anomalieCount: number;
  kmTotali: number | null;
  segnali: SegnaleChip[];
  segnaliTotal: number;
  hasUrgentSignals: boolean;
};

const DAY_MS = 24 * 60 * 60 * 1000;

function startOfDay(date: Date): Date {
  return new Date(date.getFullYear(), date.getMonth(), date.getDate(), 0, 0, 0, 0);
}

function evaluateMaintenanceStatusInline(
  ts: number | null,
  today: Date,
): { status: MaintenanceStatus; daysToDeadline: number | null } {
  if (ts === null) return { status: "SENZA_DATA", daysToDeadline: null };
  const target = new Date(ts);
  const days = Math.floor(
    (startOfDay(target).getTime() - startOfDay(today).getTime()) / DAY_MS,
  );
  if (days < 0) return { status: "SCADUTA", daysToDeadline: days };
  if (days <= 30) return { status: "IN_SCADENZA", daysToDeadline: days };
  return { status: "OK", daysToDeadline: days };
}

function parseDateFlexibleSinottica(value: string | null | undefined): Date | null {
  if (!value) return null;
  const trimmed = value.trim();
  if (!trimmed) return null;
  const direct = new Date(trimmed);
  if (!Number.isNaN(direct.getTime())) return direct;
  const m = trimmed.match(
    /^(\d{1,2})[./\-\s](\d{1,2})[./\-\s](\d{2,4})(?:[,\s]+(\d{1,2}):(\d{2}))?$/,
  );
  if (!m) return null;
  const day = Number(m[1]);
  const month = Number(m[2]) - 1;
  const yearRaw = Number(m[3]);
  const year = m[3].length === 2 ? 2000 + yearRaw : yearRaw;
  const hh = Number(m[4] ?? "12");
  const mm = Number(m[5] ?? "00");
  const d = new Date(year, month, day, hh, mm, 0, 0);
  return Number.isNaN(d.getTime()) ? null : d;
}

function deriveIconKind(
  categoria: string,
  tipo: "motrice" | "cisterna" | null,
): "trattore" | "cisterna" | "rimorchio" {
  const cat = (categoria ?? "").toLowerCase();
  if (tipo === "cisterna" || cat.includes("cisterna")) return "cisterna";
  if (cat.includes("rimorchio") || cat.includes("semirimorchio")) return "rimorchio";
  return "trattore";
}

function formatDateItDisplay(ts: number | null): string {
  if (ts === null) return "—";
  const d = new Date(ts);
  if (Number.isNaN(d.getTime())) return "—";
  const dd = String(d.getDate()).padStart(2, "0");
  const mm = String(d.getMonth() + 1).padStart(2, "0");
  const yyyy = d.getFullYear();
  return `${dd}.${mm}.${yyyy}`;
}

function formatKmInteger(value: number | null): string {
  if (value === null) return "—";
  return Math.round(value).toLocaleString("it-IT");
}

function formatKmL(value: number | null): string {
  if (value === null) return "—";
  return value.toFixed(2).replace(".", ",");
}

function deriveSegnTipo(tipoRaw: string): "freni" | "gomme" | "elettrico" | "altro" {
  const t = tipoRaw.toLowerCase();
  if (t.includes("fren")) return "freni";
  if (t.includes("gomm")) return "gomme";
  if (t.includes("elett")) return "elettrico";
  return "altro";
}

function tipoToLabel(tipo: "freni" | "gomme" | "elettrico" | "altro"): string {
  switch (tipo) {
    case "freni":
      return "Segn. freni";
    case "gomme":
      return "Segn. gomme";
    case "elettrico":
      return "Segn. elettrico";
    default:
      return "Segn. altro";
  }
}

