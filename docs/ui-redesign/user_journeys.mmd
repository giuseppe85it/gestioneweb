  subgraph J1["J1 - Inserire lavoro (Admin)"]
    J1A["Home"]:::step --> J1B["Lavori da eseguire"]:::step
    J1B --> J1C["Aggiungi + salva gruppo lavori"]:::step
    J1C --> J1D["Lavori in attesa"]:::step
