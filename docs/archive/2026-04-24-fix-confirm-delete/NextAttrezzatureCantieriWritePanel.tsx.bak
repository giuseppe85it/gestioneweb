/**
 * SPEC: docs/product/SPEC_ATTREZZATURE_CANTIERI_NEXT.md
 * Madre UI: src/pages/AttrezzatureCantieri.tsx
 * Pannello scrivente NEXT: layout madre, persistenza tramite writer NEXT.
 */

import { useEffect, useMemo, useState } from "react";
import PdfPreviewModal from "../components/PdfPreviewModal";
import { generateAttrezzatureCantieriPDFBlob } from "../utils/pdfEngine";
import {
  buildPdfShareText,
  buildWhatsAppShareUrl,
  copyTextToClipboard,
  openPreview,
  revokePdfPreviewUrl,
  sharePdfFile,
} from "../utils/pdfPreview";
import {
  buildNextAttrezzatureRegistroView,
  formatNextAttrezzatureQuantita,
  readNextAttrezzatureCantieriSnapshot,
  type NextAttrezzaturaMovimentoReadOnlyItem,
  type NextAttrezzaturaMovimentoTipo,
  type NextAttrezzaturaStatoCantiere,
  type NextAttrezzaturaStatoMateriale,
  type NextAttrezzatureCantieriSnapshot,
} from "./domain/nextAttrezzatureCantieriDomain";
import {
  createMovimentoAttrezzatura,
  deleteMovimentoAttrezzatura,
  editMovimentoAttrezzatura,
  removeEditFotoAttrezzatura,
} from "./nextAttrezzatureCantieriWriter";
import "../pages/AttrezzatureCantieri.css";

const TIPI_MOVIMENTO = ["CONSEGNATO", "SPOSTATO", "RITIRATO"] as const;
const CATEGORIE = ["TUBI", "MATERIALI", "ALTRO"] as const;
const UNITA_BASE = ["m", "pz", "kg", "set"] as const;
const UNITA_OPZIONI = [...UNITA_BASE, "altro"] as const;

type MovimentoForm = {
  id?: string;
  tipo: NextAttrezzaturaMovimentoTipo;
  data: string;
  materialeCategoria: string;
  descrizione: string;
  quantita: string;
  unita: string;
  unitaAltro: string;
  cantiereId: string;
  cantiereLabel: string;
  note: string;
  fotoUrl: string | null;
  fotoStoragePath: string | null;
  sourceCantiereId: string;
  sourceCantiereLabel: string;
};

type ExportScope = "stato" | "movimenti" | "stato_movimenti";

export type NextAttrezzatureCantieriWritePanelProps = {
  snapshot: NextAttrezzatureCantieriSnapshot;
  onAfterWrite?: () => void | Promise<void>;
};

function oggi(): string {
  const now = new Date();
  const day = String(now.getDate()).padStart(2, "0");
  const month = String(now.getMonth() + 1).padStart(2, "0");
  return `${day} ${month} ${now.getFullYear()}`;
}

function parseNumero(value: string): number {
  const parsed = Number(value.replace(",", "."));
  return Number.isFinite(parsed) ? parsed : NaN;
}

function buildInitialForm(): MovimentoForm {
  return {
    tipo: "CONSEGNATO",
    data: oggi(),
    materialeCategoria: "TUBI",
    descrizione: "",
    quantita: "",
    unita: "m",
    unitaAltro: "",
    cantiereId: "",
    cantiereLabel: "",
    note: "",
    fotoUrl: null,
    fotoStoragePath: null,
    sourceCantiereId: "",
    sourceCantiereLabel: "",
  };
}

function splitUnita(value: string): { unita: string; unitaAltro: string } {
  if (!value) return { unita: "m", unitaAltro: "" };
  if ((UNITA_BASE as readonly string[]).includes(value)) return { unita: value, unitaAltro: "" };
  return { unita: "altro", unitaAltro: value };
}

function formatQuantita(value: number): string {
  if (Number.isNaN(value)) return "0";
  if (Number.isInteger(value)) return String(value);
  return value.toFixed(2).replace(/\.00$/, "");
}

function formatDataExport(value: string | null): string {
  const trimmed = String(value || "").trim();
  if (!trimmed) return "-";

  const parts = trimmed.split(" ");
  if (parts.length === 3) {
    const [day, month, year] = parts;
    return `${String(day).padStart(2, "0")}/${String(month).padStart(2, "0")}/${year}`;
  }

  const parsed = new Date(trimmed);
  if (Number.isNaN(parsed.getTime())) return trimmed;

  const day = String(parsed.getDate()).padStart(2, "0");
  const month = String(parsed.getMonth() + 1).padStart(2, "0");
  return `${day}/${month}/${parsed.getFullYear()}`;
}

function formatCantiereExport(labelRaw: string | null, idRaw: string | null): string {
  const label = String(labelRaw || "").trim();
  const id = String(idRaw || "").trim();
  if (label && id && label.toUpperCase() !== id.toUpperCase()) {
    return `${label} (${id})`;
  }
  return label || id || "Senza cantiere";
}

function buildStatoAttualeFromMovimenti(
  source: readonly NextAttrezzaturaMovimentoReadOnlyItem[],
): NextAttrezzaturaStatoCantiere[] {
  const cantieri = new Map<
    string,
    {
      id: string;
      label: string;
      materiali: Map<string, NextAttrezzaturaStatoMateriale>;
    }
  >();

  const resolveCantiere = (idRaw: string | null, labelRaw: string | null) => {
    const id = String(idRaw || "").trim() || String(labelRaw || "").trim() || "SENZA_CANTIERE";
    const label = String(labelRaw || "").trim() || String(idRaw || "").trim() || "Senza cantiere";
    const key = `${id}__${label}`.toUpperCase();
    if (!cantieri.has(key)) {
      cantieri.set(key, { id, label, materiali: new Map() });
    }
    return cantieri.get(key)!;
  };

  const addQty = (
    cantiereId: string | null,
    cantiereLabel: string | null,
    descrizione: string,
    unita: string,
    delta: number,
  ) => {
    if (!descrizione || !unita || !Number.isFinite(delta) || delta === 0) return;
    const cantiere = resolveCantiere(cantiereId, cantiereLabel);
    const materialKey = `${descrizione}__${unita}`.toLowerCase();
    const existing = cantiere.materiali.get(materialKey);
    const nextQty = (existing?.quantita || 0) + delta;
    cantiere.materiali.set(materialKey, {
      descrizione,
      unita,
      quantita: nextQty,
    });
  };

  source.forEach((movimento) => {
    const quantity = Number(movimento.quantita) || 0;
    const descrizione = String(movimento.descrizione || "").trim();
    const unita = String(movimento.unita || "").trim();
    if (!descrizione || !unita || !quantity) return;

    if (movimento.tipo === "CONSEGNATO") {
      addQty(movimento.cantiereId, movimento.cantiereLabel, descrizione, unita, quantity);
      return;
    }

    if (movimento.tipo === "SPOSTATO") {
      if (movimento.sourceCantiereId || movimento.sourceCantiereLabel) {
        addQty(
          movimento.sourceCantiereId,
          movimento.sourceCantiereLabel,
          descrizione,
          unita,
          -quantity,
        );
      }
      addQty(movimento.cantiereId, movimento.cantiereLabel, descrizione, unita, quantity);
      return;
    }

    if (movimento.tipo === "RITIRATO") {
      addQty(movimento.cantiereId, movimento.cantiereLabel, descrizione, unita, -quantity);
      addQty("MAGAZZINO", "MAGAZZINO", descrizione, unita, quantity);
    }
  });

  return Array.from(cantieri.values())
    .map((cantiere) => {
      const materiali = Array.from(cantiere.materiali.values())
        .filter((materiale) => materiale.quantita !== 0)
        .sort((left, right) => left.descrizione.localeCompare(right.descrizione));
      return { ...cantiere, materiali };
    })
    .filter((cantiere) => cantiere.materiali.length > 0);
}

function validateForm(form: MovimentoForm): {
  descrizione: string;
  quantita: number;
  unitaFinale: string;
  cantiereId: string;
  cantiereLabel: string;
} | null {
  const descrizione = form.descrizione.trim();
  if (!descrizione) return null;

  const quantita = parseNumero(form.quantita);
  if (!Number.isFinite(quantita) || quantita <= 0) return null;

  const unitaFinale = form.unita === "altro" ? form.unitaAltro.trim() : form.unita;
  if (!unitaFinale) return null;

  const cantiereId = form.cantiereId.trim();
  const cantiereLabel = form.cantiereLabel.trim() || cantiereId;
  if (!cantiereLabel) return null;

  return { descrizione, quantita, unitaFinale, cantiereId, cantiereLabel };
}

function resolveValidationMessage(form: MovimentoForm): string | null {
  if (!form.descrizione.trim()) return "Inserisci una descrizione.";
  const quantita = parseNumero(form.quantita);
  if (!Number.isFinite(quantita) || quantita <= 0) return "Inserisci una quantita valida.";
  const unitaFinale = form.unita === "altro" ? form.unitaAltro.trim() : form.unita;
  if (!unitaFinale) return "Inserisci una unita valida.";
  const cantiereId = form.cantiereId.trim();
  const cantiereLabel = form.cantiereLabel.trim() || cantiereId;
  if (!cantiereLabel) return "Inserisci un cantiere valido.";
  return null;
}

function buildEditForm(record: NextAttrezzaturaMovimentoReadOnlyItem): MovimentoForm {
  const unita = splitUnita(record.unita);
  return {
    id: record.id,
    tipo: record.tipo,
    data: record.data || oggi(),
    materialeCategoria: record.materialeCategoria || "TUBI",
    descrizione: record.descrizione || "",
    quantita: record.quantita ? String(record.quantita) : "",
    unita: unita.unita,
    unitaAltro: unita.unitaAltro,
    cantiereId: record.cantiereId || "",
    cantiereLabel: record.cantiereLabel || "",
    note: record.note || "",
    fotoUrl: record.fotoUrl || null,
    fotoStoragePath: record.fotoStoragePath || null,
    sourceCantiereId: record.sourceCantiereId || "",
    sourceCantiereLabel: record.sourceCantiereLabel || "",
  };
}

function revokePreview(url: string | null): void {
  if (url) URL.revokeObjectURL(url);
}

export default function NextAttrezzatureCantieriWritePanel({
  snapshot,
  onAfterWrite,
}: NextAttrezzatureCantieriWritePanelProps) {
  const [localSnapshot, setLocalSnapshot] =
    useState<NextAttrezzatureCantieriSnapshot>(snapshot);
  const [form, setForm] = useState<MovimentoForm>(() => buildInitialForm());
  const [fotoFile, setFotoFile] = useState<File | null>(null);
  const [fotoPreview, setFotoPreview] = useState<string | null>(null);
  const [saving, setSaving] = useState(false);
  const [error, setError] = useState<string | null>(null);

  const [filterText, setFilterText] = useState("");
  const [filterTipo, setFilterTipo] = useState<"tutti" | NextAttrezzaturaMovimentoTipo>("tutti");
  const [filterCategoria, setFilterCategoria] = useState("tutte");
  const [showAllStato, setShowAllStato] = useState(false);
  const [showAllRegistro, setShowAllRegistro] = useState(false);
  const [exportScope, setExportScope] = useState<ExportScope>("stato_movimenti");
  const [pdfPreviewOpen, setPdfPreviewOpen] = useState(false);
  const [pdfPreviewUrl, setPdfPreviewUrl] = useState<string | null>(null);
  const [pdfPreviewBlob, setPdfPreviewBlob] = useState<Blob | null>(null);
  const [pdfPreviewFileName, setPdfPreviewFileName] = useState("attrezzature-cantieri.pdf");
  const [pdfShareHint, setPdfShareHint] = useState<string | null>(null);

  const [editRecord, setEditRecord] = useState<NextAttrezzaturaMovimentoReadOnlyItem | null>(null);
  const [editForm, setEditForm] = useState<MovimentoForm | null>(null);
  const [editFotoFile, setEditFotoFile] = useState<File | null>(null);
  const [editFotoPreview, setEditFotoPreview] = useState<string | null>(null);
  const [editSaving, setEditSaving] = useState(false);

  useEffect(() => {
    setLocalSnapshot(snapshot);
  }, [snapshot]);

  useEffect(() => {
    return () => {
      revokePreview(fotoPreview);
      revokePreview(editFotoPreview);
    };
  }, [editFotoPreview, fotoPreview]);

  useEffect(() => {
    return () => {
      revokePdfPreviewUrl(pdfPreviewUrl);
    };
  }, [pdfPreviewUrl]);

  const refreshLocalSnapshot = async () => {
    const fresh = await readNextAttrezzatureCantieriSnapshot();
    setLocalSnapshot(fresh);
    await onAfterWrite?.();
  };

  const formatFileDate = () => {
    const now = new Date();
    const day = String(now.getDate()).padStart(2, "0");
    const month = String(now.getMonth() + 1).padStart(2, "0");
    return `${day}-${month}-${now.getFullYear()}`;
  };

  const closePdfPreview = () => {
    revokePdfPreviewUrl(pdfPreviewUrl);
    setPdfPreviewOpen(false);
    setPdfPreviewUrl(null);
    setPdfPreviewBlob(null);
    setPdfShareHint(null);
  };

  const buildPdfShareMessage = () =>
    buildPdfShareText({
      contextLabel: "Attrezzature cantieri",
      dateLabel: formatFileDate(),
      fileName: pdfPreviewFileName || "attrezzature-cantieri.pdf",
      url: pdfPreviewUrl,
    });

  const handleSharePDF = async () => {
    if (!pdfPreviewBlob) {
      const copied = await copyTextToClipboard(buildPdfShareMessage());
      setPdfShareHint(copied ? "Link copiato." : "Apri prima un'anteprima PDF.");
      return;
    }

    const result = await sharePdfFile({
      blob: pdfPreviewBlob,
      fileName: pdfPreviewFileName || "attrezzature-cantieri.pdf",
      title: "Anteprima PDF attrezzature cantieri",
      text: buildPdfShareMessage(),
    });

    if (result.status === "shared") {
      setPdfShareHint("PDF condiviso.");
      return;
    }
    if (result.status === "aborted") return;

    const copied = await copyTextToClipboard(buildPdfShareMessage());
    setPdfShareHint(
      copied ? "Condivisione non disponibile: testo copiato." : "Condivisione non disponibile.",
    );
  };

  const handleCopyPDFText = async () => {
    const copied = await copyTextToClipboard(buildPdfShareMessage());
    setPdfShareHint(copied ? "Testo copiato." : "Copia non disponibile.");
  };

  const handleWhatsAppPDF = () => {
    window.open(buildWhatsAppShareUrl(buildPdfShareMessage()), "_blank", "noopener,noreferrer");
  };

  const handleFotoSelect = (
    file: File | null,
    setFile: (nextFile: File | null) => void,
    setPreview: (nextPreview: string | null) => void,
    currentPreview: string | null,
  ) => {
    revokePreview(currentPreview);
    if (!file) {
      setFile(null);
      setPreview(null);
      return;
    }
    setFile(file);
    setPreview(URL.createObjectURL(file));
  };

  const handleResetForm = () => {
    handleFotoSelect(null, setFotoFile, setFotoPreview, fotoPreview);
    setForm(buildInitialForm());
    setError(null);
  };

  const handleSave = async () => {
    setError(null);
    const validationMessage = resolveValidationMessage(form);
    if (validationMessage) {
      setError(validationMessage);
      return;
    }
    const validated = validateForm(form);
    if (!validated) return;

    try {
      setSaving(true);
      await createMovimentoAttrezzatura({
        tipo: form.tipo,
        data: form.data.trim() || oggi(),
        materialeCategoria: form.materialeCategoria || "TUBI",
        descrizione: validated.descrizione,
        quantita: validated.quantita,
        unita: validated.unitaFinale,
        cantiereId: validated.cantiereId,
        cantiereLabel: validated.cantiereLabel,
        note: form.note.trim() || null,
        fotoFile,
        sourceCantiereId: form.tipo === "SPOSTATO" ? form.sourceCantiereId.trim() || null : null,
        sourceCantiereLabel:
          form.tipo === "SPOSTATO"
            ? form.sourceCantiereLabel.trim() || form.sourceCantiereId.trim() || null
            : null,
      });
      await refreshLocalSnapshot();
      handleResetForm();
    } catch (err) {
      console.error("Errore salvataggio movimento:", err);
      setError("Errore salvataggio movimento.");
    } finally {
      setSaving(false);
    }
  };

  const handleDelete = async (record: NextAttrezzaturaMovimentoReadOnlyItem) => {
    setError(null);
    try {
      await deleteMovimentoAttrezzatura({
        record,
        onDeleted: refreshLocalSnapshot,
      });
    } catch (err) {
      console.error("Errore eliminazione movimento:", err);
      setError("Errore eliminazione movimento.");
    }
  };

  const handleEditOpen = (record: NextAttrezzaturaMovimentoReadOnlyItem) => {
    setEditRecord(record);
    setEditForm(buildEditForm(record));
    setEditFotoFile(null);
    revokePreview(editFotoPreview);
    setEditFotoPreview(null);
    setError(null);
  };

  const handleEditClose = () => {
    revokePreview(editFotoPreview);
    setEditRecord(null);
    setEditForm(null);
    setEditFotoFile(null);
    setEditFotoPreview(null);
  };

  const handleEditRemovePhoto = async () => {
    if (!editForm) return;
    try {
      await removeEditFotoAttrezzatura({ fotoStoragePath: editForm.fotoStoragePath });
    } catch {
      // Il writer gia gestisce il delete best-effort.
    }
    setEditForm({ ...editForm, fotoUrl: null, fotoStoragePath: null });
    handleFotoSelect(null, setEditFotoFile, setEditFotoPreview, editFotoPreview);
  };

  const handleEditSave = async () => {
    if (!editForm || !editRecord) return;

    setError(null);
    const validationMessage = resolveValidationMessage(editForm);
    if (validationMessage) {
      setError(validationMessage);
      return;
    }
    const validated = validateForm(editForm);
    if (!validated) return;

    try {
      setEditSaving(true);
      await editMovimentoAttrezzatura({
        originalRecord: editRecord,
        updatedFields: {
          tipo: editForm.tipo,
          data: editForm.data.trim() || oggi(),
          materialeCategoria: editForm.materialeCategoria || "TUBI",
          descrizione: validated.descrizione,
          quantita: validated.quantita,
          unita: validated.unitaFinale,
          cantiereId: validated.cantiereId,
          cantiereLabel: validated.cantiereLabel,
          note: editForm.note.trim() || null,
          fotoUrl: editForm.fotoUrl,
          fotoStoragePath: editForm.fotoStoragePath,
          sourceCantiereId:
            editForm.tipo === "SPOSTATO" ? editForm.sourceCantiereId.trim() || null : null,
          sourceCantiereLabel:
            editForm.tipo === "SPOSTATO"
              ? editForm.sourceCantiereLabel.trim() || editForm.sourceCantiereId.trim() || null
              : null,
        },
        newFotoFile: editFotoFile,
        onSaved: refreshLocalSnapshot,
      });
      handleEditClose();
    } catch (err) {
      console.error("Errore modifica movimento:", err);
      setError("Errore modifica movimento.");
    } finally {
      setEditSaving(false);
    }
  };

  const normalizedCategoria = filterCategoria === "tutte" ? null : filterCategoria;
  const movimentiOrdinati = useMemo(
    () =>
      buildNextAttrezzatureRegistroView(localSnapshot, {
        query: filterText,
        tipo: filterTipo,
        categoria: normalizedCategoria,
      }),
    [filterText, filterTipo, localSnapshot, normalizedCategoria],
  );

  const categorieFiltro = useMemo(() => {
    const entries = new Set<string>([...CATEGORIE, ...localSnapshot.categories]);
    return Array.from(entries).sort((left, right) =>
      left.localeCompare(right, "it", { sensitivity: "base" }),
    );
  }, [localSnapshot.categories]);

  const exportScopeLabel = useMemo(() => {
    if (exportScope === "stato") return "Solo stato attuale";
    if (exportScope === "movimenti") return "Solo movimenti";
    return "Stato attuale + movimenti";
  }, [exportScope]);

  const filtriRegistroAttivi = useMemo(() => {
    const parts: string[] = [];
    if (filterText.trim()) parts.push(`ricerca: ${filterText.trim()}`);
    if (filterTipo !== "tutti") parts.push(`tipo: ${filterTipo}`);
    if (filterCategoria !== "tutte") parts.push(`categoria: ${filterCategoria}`);
    return parts;
  }, [filterCategoria, filterText, filterTipo]);

  const filtriRegistroLabel = useMemo(() => {
    if (filtriRegistroAttivi.length === 0) return "Nessun filtro attivo";
    return filtriRegistroAttivi.join(" | ");
  }, [filtriRegistroAttivi]);

  const statoExport = useMemo(
    () => buildStatoAttualeFromMovimenti(movimentiOrdinati),
    [movimentiOrdinati],
  );

  const exportStateRows = useMemo(
    () =>
      statoExport.flatMap((cantiere) =>
        cantiere.materiali.map((materiale) => ({
          cantiere: formatCantiereExport(cantiere.label, cantiere.id),
          materiale: materiale.descrizione,
          quantita: `${formatQuantita(materiale.quantita)} ${materiale.unita}`,
        })),
      ),
    [statoExport],
  );

  const exportMovementRows = useMemo(
    () =>
      movimentiOrdinati.map((movimento) => ({
        data: formatDataExport(movimento.data),
        tipo: movimento.tipo,
        destinazione: formatCantiereExport(movimento.cantiereLabel, movimento.cantiereId),
        materiale:
          movimento.materialeCategoria && movimento.materialeCategoria !== "-"
            ? `${movimento.descrizione} - ${movimento.materialeCategoria}`
            : movimento.descrizione,
        quantita: `${formatQuantita(movimento.quantita)} ${movimento.unita}`,
        origine:
          movimento.tipo === "SPOSTATO" &&
          (movimento.sourceCantiereLabel || movimento.sourceCantiereId)
            ? formatCantiereExport(
                movimento.sourceCantiereLabel,
                movimento.sourceCantiereId,
              )
            : "-",
        note: String(movimento.note || "").trim(),
      })),
    [movimentiOrdinati],
  );

  const exportCountSummary = useMemo(
    () => ({
      statoCantieri: statoExport.length,
      statoMateriali: exportStateRows.length,
      movimenti: exportMovementRows.length,
    }),
    [exportMovementRows.length, exportStateRows.length, statoExport.length],
  );

  const handleExportPdf = async () => {
    const includeStato = exportScope === "stato" || exportScope === "stato_movimenti";
    const includeMovimenti = exportScope === "movimenti" || exportScope === "stato_movimenti";
    const noStatoData = !includeStato || exportStateRows.length === 0;
    const noMovimentiData = !includeMovimenti || exportMovementRows.length === 0;

    if (noStatoData && noMovimentiData) {
      setError("Nessun dato disponibile per l'export con la selezione corrente.");
      return;
    }

    try {
      setError(null);
      const fileDate = formatFileDate();
      const preview = await openPreview({
        source: async () =>
          generateAttrezzatureCantieriPDFBlob({
            title: "Attrezzature cantieri",
            generatedAt: formatDataExport(oggi()),
            exportScopeLabel,
            filtersLabel: filtriRegistroLabel,
            statoRows: includeStato ? exportStateRows : [],
            movimentoRows: includeMovimenti ? exportMovementRows : [],
            statoCantieriCount: includeStato ? exportCountSummary.statoCantieri : 0,
            statoMaterialiCount: includeStato ? exportCountSummary.statoMateriali : 0,
            movimentiCount: includeMovimenti ? exportCountSummary.movimenti : 0,
            fileName: `attrezzature-cantieri-${fileDate}`,
          }),
        fileName: `attrezzature-cantieri-${fileDate}.pdf`,
        previousUrl: pdfPreviewUrl,
      });
      setPdfShareHint(null);
      setPdfPreviewBlob(preview.blob);
      setPdfPreviewFileName(preview.fileName);
      setPdfPreviewUrl(preview.url);
      setPdfPreviewOpen(true);
    } catch (err) {
      console.error("Errore generazione PDF attrezzature NEXT:", err);
      setError("Errore durante la generazione del PDF.");
      window.alert("Errore durante la generazione del PDF");
    }
  };

  const statoVisibile = showAllStato
    ? localSnapshot.statoAttuale
    : localSnapshot.statoAttuale.slice(0, 5);
  const movimentiVisibili = showAllRegistro ? movimentiOrdinati : movimentiOrdinati.slice(0, 5);

  return (
    <>
      <section className="ac-section ac-export-section">
        <div className="ac-section-head">
          <div>
            <h2>Configurazione export PDF</h2>
            <span>Scegli cosa esportare prima di aprire l'anteprima.</span>
          </div>
          <button className="ac-primary-btn" type="button" onClick={handleExportPdf}>
            Esporta PDF
          </button>
        </div>

        <div className="ac-export-grid">
          <div className="ac-export-group">
            <div className="ac-export-label">Ambito export</div>
            <div className="ac-export-scopes" role="radiogroup" aria-label="Ambito export PDF">
              <button
                type="button"
                className={`ac-scope-btn ${exportScope === "stato" ? "is-active" : ""}`}
                onClick={() => setExportScope("stato")}
              >
                Stato attuale
              </button>
              <button
                type="button"
                className={`ac-scope-btn ${exportScope === "movimenti" ? "is-active" : ""}`}
                onClick={() => setExportScope("movimenti")}
              >
                Movimenti
              </button>
              <button
                type="button"
                className={`ac-scope-btn ${exportScope === "stato_movimenti" ? "is-active" : ""}`}
                onClick={() => setExportScope("stato_movimenti")}
              >
                Stato + movimenti
              </button>
            </div>
          </div>

          <div className="ac-export-group">
            <div className="ac-export-label">Filtri applicati</div>
            <div className="ac-export-note">
              I movimenti esportati usano sempre i filtri correnti del registro. Lo stato
              nel PDF viene ricalcolato sugli stessi movimenti filtrati per evitare
              incoerenze.
            </div>
            <div className="ac-export-filters">{filtriRegistroLabel}</div>
          </div>
        </div>

        <div className="ac-export-summary">
          <div className="ac-export-chip">
            <strong>Ambito</strong>
            <span>{exportScopeLabel}</span>
          </div>
          <div className="ac-export-chip">
            <strong>Stato</strong>
            <span>
              {exportCountSummary.statoCantieri} cantieri / {exportCountSummary.statoMateriali} materiali
            </span>
          </div>
          <div className="ac-export-chip">
            <strong>Movimenti</strong>
            <span>{exportCountSummary.movimenti} righe</span>
          </div>
        </div>
      </section>

      <div className="ac-grid">
        <div className="ac-col">
          <section className="ac-section ac-form-section">
            <div className="ac-section-head">
              <div>
                <h2>Nuovo movimento</h2>
                <span>Consegna, spostamento o ritiro attrezzature</span>
              </div>
            </div>

            {error ? <div className="ac-error">{error}</div> : null}

            <div className="ac-form">
              <label className="ac-label">
                Tipo movimento
                <select
                  className="ac-input"
                  value={form.tipo}
                  onChange={(event) =>
                    setForm((prev) => ({
                      ...prev,
                      tipo: event.target.value as NextAttrezzaturaMovimentoTipo,
                    }))
                  }
                >
                  {TIPI_MOVIMENTO.map((tipo) => (
                    <option key={tipo} value={tipo}>
                      {tipo}
                    </option>
                  ))}
                </select>
              </label>

              <div className="ac-row">
                <label className="ac-label flex1">
                  Data
                  <input
                    className="ac-input"
                    type="text"
                    placeholder="gg mm aaaa"
                    value={form.data}
                    onChange={(event) =>
                      setForm((prev) => ({ ...prev, data: event.target.value }))
                    }
                  />
                </label>

                <label className="ac-label flex1">
                  Categoria
                  <select
                    className="ac-input"
                    value={form.materialeCategoria}
                    onChange={(event) =>
                      setForm((prev) => ({ ...prev, materialeCategoria: event.target.value }))
                    }
                  >
                    {CATEGORIE.map((categoria) => (
                      <option key={categoria} value={categoria}>
                        {categoria}
                      </option>
                    ))}
                  </select>
                </label>
              </div>

              <label className="ac-label">
                Descrizione materiale
                <input
                  className="ac-input"
                  type="text"
                  placeholder="Es. TUBI 40MM"
                  value={form.descrizione}
                  onChange={(event) =>
                    setForm((prev) => ({ ...prev, descrizione: event.target.value }))
                  }
                />
              </label>

              <div className="ac-row">
                <label className="ac-label flex1">
                  Quantita
                  <input
                    className="ac-input"
                    type="number"
                    value={form.quantita}
                    onChange={(event) =>
                      setForm((prev) => ({ ...prev, quantita: event.target.value }))
                    }
                  />
                </label>

                <label className="ac-label flex1">
                  Unita
                  <select
                    className="ac-input"
                    value={form.unita}
                    onChange={(event) =>
                      setForm((prev) => ({
                        ...prev,
                        unita: event.target.value,
                        unitaAltro: event.target.value === "altro" ? prev.unitaAltro : "",
                      }))
                    }
                  >
                    {UNITA_OPZIONI.map((unita) => (
                      <option key={unita} value={unita}>
                        {unita}
                      </option>
                    ))}
                  </select>
                </label>
              </div>

              {form.unita === "altro" ? (
                <label className="ac-label">
                  Unita (specifica)
                  <input
                    className="ac-input"
                    type="text"
                    value={form.unitaAltro}
                    onChange={(event) =>
                      setForm((prev) => ({ ...prev, unitaAltro: event.target.value }))
                    }
                  />
                </label>
              ) : null}

              <div className="ac-row">
                <label className="ac-label flex1">
                  Cantiere ID
                  <input
                    className="ac-input"
                    type="text"
                    placeholder="Es. CANT-12"
                    value={form.cantiereId}
                    onChange={(event) =>
                      setForm((prev) => ({ ...prev, cantiereId: event.target.value }))
                    }
                  />
                </label>

                <label className="ac-label flex1">
                  Cantiere (nome)
                  <input
                    className="ac-input"
                    type="text"
                    placeholder="Es. Via Roma"
                    value={form.cantiereLabel}
                    onChange={(event) =>
                      setForm((prev) => ({ ...prev, cantiereLabel: event.target.value }))
                    }
                  />
                </label>
              </div>

              {form.tipo === "SPOSTATO" ? (
                <>
                  <div className="ac-hint">Compila il cantiere di origine per sottrarre le quantita.</div>
                  <div className="ac-row">
                    <label className="ac-label flex1">
                      Da cantiere ID
                      <input
                        className="ac-input"
                        type="text"
                        value={form.sourceCantiereId}
                        onChange={(event) =>
                          setForm((prev) => ({ ...prev, sourceCantiereId: event.target.value }))
                        }
                      />
                    </label>

                    <label className="ac-label flex1">
                      Da cantiere (nome)
                      <input
                        className="ac-input"
                        type="text"
                        value={form.sourceCantiereLabel}
                        onChange={(event) =>
                          setForm((prev) => ({
                            ...prev,
                            sourceCantiereLabel: event.target.value,
                          }))
                        }
                      />
                    </label>
                  </div>
                </>
              ) : null}

              <label className="ac-label">
                Note (opzionale)
                <textarea
                  className="ac-input ac-textarea"
                  value={form.note}
                  onChange={(event) => setForm((prev) => ({ ...prev, note: event.target.value }))}
                />
              </label>

              <div className="ac-photo">
                <label className="ac-label">
                  Foto (opzionale)
                  <input
                    className="ac-file"
                    type="file"
                    accept="image/*"
                    capture="environment"
                    onChange={(event) =>
                      handleFotoSelect(
                        event.target.files?.[0] || null,
                        setFotoFile,
                        setFotoPreview,
                        fotoPreview,
                      )
                    }
                  />
                </label>
                {fotoPreview ? (
                  <div className="ac-photo-preview">
                    <img src={fotoPreview} alt="Anteprima foto" />
                    <button
                      type="button"
                      className="ac-link-btn"
                      onClick={() =>
                        handleFotoSelect(null, setFotoFile, setFotoPreview, fotoPreview)
                      }
                    >
                      Rimuovi foto
                    </button>
                  </div>
                ) : null}
              </div>

              <div style={{ display: "flex", gap: 8, flexWrap: "wrap" }}>
                <button className="ac-primary-btn" type="button" onClick={handleSave} disabled={saving}>
                  {saving ? "Salvataggio..." : "Salva movimento"}
                </button>
                <button className="ac-danger-btn" type="button" onClick={handleResetForm} disabled={saving}>
                  Elimina
                </button>
              </div>
            </div>
          </section>

          <section className="ac-section ac-stato-section">
            <div className="ac-section-head">
              <div>
                <h2>Stato attuale</h2>
                <span>Dove sono le attrezzature ora</span>
              </div>
              {localSnapshot.statoAttuale.length > 5 ? (
                <button
                  className="ac-link-btn"
                  type="button"
                  onClick={() => setShowAllStato((prev) => !prev)}
                >
                  {showAllStato ? "Mostra meno" : "Mostra tutto"}
                </button>
              ) : null}
            </div>

            {localSnapshot.statoAttuale.length === 0 ? (
              <div className="ac-empty">Nessun movimento registrato.</div>
            ) : (
              <div className="ac-status-grid">
                {statoVisibile.map((cantiere) => (
                  <div className="ac-status-card" key={`${cantiere.id}-${cantiere.label}`}>
                    <div className="ac-status-head">
                      <div className="ac-status-title">{cantiere.label}</div>
                      <div className="ac-status-sub">{cantiere.id}</div>
                    </div>
                    <div className="ac-status-list">
                      {cantiere.materiali.map((materiale) => (
                        <div
                          key={`${cantiere.id}-${materiale.descrizione}-${materiale.unita}`}
                          className="ac-status-row"
                        >
                          <span>{materiale.descrizione}</span>
                          <span className="ac-qty">
                            {formatNextAttrezzatureQuantita(materiale.quantita)} {materiale.unita}
                          </span>
                        </div>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </section>
        </div>

        <div className="ac-col">
          <section className="ac-section ac-registro-section">
            <div className="ac-section-head">
              <div>
                <h2>Registro movimenti</h2>
                <span>{movimentiOrdinati.length} movimenti</span>
              </div>
              {movimentiOrdinati.length > 5 ? (
                <button
                  className="ac-link-btn"
                  type="button"
                  onClick={() => setShowAllRegistro((prev) => !prev)}
                >
                  {showAllRegistro ? "Mostra meno" : "Mostra tutto"}
                </button>
              ) : null}
            </div>

            <div className="ac-filters">
              <label className="ac-label">
                Ricerca
                <input
                  className="ac-input"
                  type="text"
                  placeholder="cantiere, descrizione"
                  value={filterText}
                  onChange={(event) => setFilterText(event.target.value)}
                />
              </label>

              <label className="ac-label">
                Tipo
                <select
                  className="ac-input"
                  value={filterTipo}
                  onChange={(event) =>
                    setFilterTipo(event.target.value as "tutti" | NextAttrezzaturaMovimentoTipo)
                  }
                >
                  <option value="tutti">tutti</option>
                  {TIPI_MOVIMENTO.map((tipo) => (
                    <option key={tipo} value={tipo}>
                      {tipo}
                    </option>
                  ))}
                </select>
              </label>

              <label className="ac-label">
                Categoria
                <select
                  className="ac-input"
                  value={filterCategoria}
                  onChange={(event) => setFilterCategoria(event.target.value)}
                >
                  <option value="tutte">tutte</option>
                  {categorieFiltro.map((categoria) => (
                    <option key={categoria} value={categoria}>
                      {categoria}
                    </option>
                  ))}
                </select>
              </label>
            </div>

            <div className="ac-registro-list">
              {movimentiOrdinati.length === 0 ? (
                <div className="ac-empty">Nessun movimento registrato.</div>
              ) : (
                movimentiVisibili.map((movimento) => (
                  <div key={movimento.id} className="ac-registro-row">
                    <div className="ac-registro-main">
                      <div className="ac-registro-head">
                        <span className="ac-date">{movimento.data ?? "-"}</span>
                        <span className={`ac-badge is-${movimento.tipo.toLowerCase()}`}>
                          {movimento.tipo}
                        </span>
                      </div>
                      <div className="ac-registro-title">{movimento.descrizione}</div>
                      <div className="ac-registro-meta">
                        <span className="ac-meta-item">{movimento.materialeCategoria || "-"}</span>
                        <span className="ac-meta-item">
                          {formatNextAttrezzatureQuantita(movimento.quantita)} {movimento.unita}
                        </span>
                        <span className="ac-meta-item">
                          {movimento.cantiereLabel || movimento.cantiereId}
                        </span>
                      </div>
                      {movimento.tipo === "SPOSTATO" &&
                      (movimento.sourceCantiereId || movimento.sourceCantiereLabel) ? (
                        <div className="ac-registro-meta">
                          <span className="ac-meta-item">
                            Da: {movimento.sourceCantiereLabel || movimento.sourceCantiereId}
                          </span>
                        </div>
                      ) : null}
                      {movimento.note ? <div className="ac-note">{movimento.note}</div> : null}
                      {movimento.fotoUrl ? (
                        <div className="ac-photo-thumb">
                          <img src={movimento.fotoUrl} alt="Foto movimento" />
                        </div>
                      ) : null}
                    </div>

                    <div className="ac-registro-actions">
                      <button
                        className="ac-secondary-btn"
                        type="button"
                        onClick={() => handleEditOpen(movimento)}
                      >
                        Modifica
                      </button>
                      <button
                        className="ac-danger-btn"
                        type="button"
                        onClick={() => handleDelete(movimento)}
                      >
                        Elimina
                      </button>
                    </div>
                  </div>
                ))
              )}
            </div>
          </section>
        </div>
      </div>

      {editForm ? (
        <div className="ac-modal">
          <div className="ac-modal-box">
            <div className="ac-modal-head">
              <div>
                <h3>Modifica movimento</h3>
                <span>ID: {editForm.id}</span>
              </div>
              <button className="ac-link-btn" type="button" onClick={handleEditClose}>
                Chiudi
              </button>
            </div>

            <div className="ac-form">
              <label className="ac-label">
                Tipo movimento
                <select
                  className="ac-input"
                  value={editForm.tipo}
                  onChange={(event) =>
                    setEditForm((prev) =>
                      prev
                        ? { ...prev, tipo: event.target.value as NextAttrezzaturaMovimentoTipo }
                        : prev,
                    )
                  }
                >
                  {TIPI_MOVIMENTO.map((tipo) => (
                    <option key={tipo} value={tipo}>
                      {tipo}
                    </option>
                  ))}
                </select>
              </label>

              <div className="ac-row">
                <label className="ac-label flex1">
                  Data
                  <input
                    className="ac-input"
                    type="text"
                    value={editForm.data}
                    onChange={(event) =>
                      setEditForm((prev) => (prev ? { ...prev, data: event.target.value } : prev))
                    }
                  />
                </label>

                <label className="ac-label flex1">
                  Categoria
                  <select
                    className="ac-input"
                    value={editForm.materialeCategoria}
                    onChange={(event) =>
                      setEditForm((prev) =>
                        prev ? { ...prev, materialeCategoria: event.target.value } : prev,
                      )
                    }
                  >
                    {CATEGORIE.map((categoria) => (
                      <option key={categoria} value={categoria}>
                        {categoria}
                      </option>
                    ))}
                  </select>
                </label>
              </div>

              <label className="ac-label">
                Descrizione materiale
                <input
                  className="ac-input"
                  type="text"
                  value={editForm.descrizione}
                  onChange={(event) =>
                    setEditForm((prev) =>
                      prev ? { ...prev, descrizione: event.target.value } : prev,
                    )
                  }
                />
              </label>

              <div className="ac-row">
                <label className="ac-label flex1">
                  Quantita
                  <input
                    className="ac-input"
                    type="number"
                    value={editForm.quantita}
                    onChange={(event) =>
                      setEditForm((prev) =>
                        prev ? { ...prev, quantita: event.target.value } : prev,
                      )
                    }
                  />
                </label>
                <label className="ac-label flex1">
                  Unita
                  <select
                    className="ac-input"
                    value={editForm.unita}
                    onChange={(event) =>
                      setEditForm((prev) =>
                        prev
                          ? {
                              ...prev,
                              unita: event.target.value,
                              unitaAltro: event.target.value === "altro" ? prev.unitaAltro : "",
                            }
                          : prev,
                      )
                    }
                  >
                    {UNITA_OPZIONI.map((unita) => (
                      <option key={unita} value={unita}>
                        {unita}
                      </option>
                    ))}
                  </select>
                </label>
              </div>

              {editForm.unita === "altro" ? (
                <label className="ac-label">
                  Unita (specifica)
                  <input
                    className="ac-input"
                    type="text"
                    value={editForm.unitaAltro}
                    onChange={(event) =>
                      setEditForm((prev) =>
                        prev ? { ...prev, unitaAltro: event.target.value } : prev,
                      )
                    }
                  />
                </label>
              ) : null}

              <div className="ac-row">
                <label className="ac-label flex1">
                  Cantiere ID
                  <input
                    className="ac-input"
                    type="text"
                    value={editForm.cantiereId}
                    onChange={(event) =>
                      setEditForm((prev) =>
                        prev ? { ...prev, cantiereId: event.target.value } : prev,
                      )
                    }
                  />
                </label>
                <label className="ac-label flex1">
                  Cantiere (nome)
                  <input
                    className="ac-input"
                    type="text"
                    value={editForm.cantiereLabel}
                    onChange={(event) =>
                      setEditForm((prev) =>
                        prev ? { ...prev, cantiereLabel: event.target.value } : prev,
                      )
                    }
                  />
                </label>
              </div>

              {editForm.tipo === "SPOSTATO" ? (
                <>
                  <div className="ac-hint">Compila il cantiere di origine per sottrarre le quantita.</div>
                  <div className="ac-row">
                    <label className="ac-label flex1">
                      Da cantiere ID
                      <input
                        className="ac-input"
                        type="text"
                        value={editForm.sourceCantiereId}
                        onChange={(event) =>
                          setEditForm((prev) =>
                            prev ? { ...prev, sourceCantiereId: event.target.value } : prev,
                          )
                        }
                      />
                    </label>
                    <label className="ac-label flex1">
                      Da cantiere (nome)
                      <input
                        className="ac-input"
                        type="text"
                        value={editForm.sourceCantiereLabel}
                        onChange={(event) =>
                          setEditForm((prev) =>
                            prev ? { ...prev, sourceCantiereLabel: event.target.value } : prev,
                          )
                        }
                      />
                    </label>
                  </div>
                </>
              ) : null}

              <label className="ac-label">
                Note
                <textarea
                  className="ac-input ac-textarea"
                  value={editForm.note}
                  onChange={(event) =>
                    setEditForm((prev) => (prev ? { ...prev, note: event.target.value } : prev))
                  }
                />
              </label>

              <div className="ac-photo">
                <label className="ac-label">
                  Foto
                  <input
                    className="ac-file"
                    type="file"
                    accept="image/*"
                    capture="environment"
                    onChange={(event) =>
                      handleFotoSelect(
                        event.target.files?.[0] || null,
                        setEditFotoFile,
                        setEditFotoPreview,
                        editFotoPreview,
                      )
                    }
                  />
                </label>

                {editFotoPreview || editForm.fotoUrl ? (
                  <div className="ac-photo-preview">
                    <img src={editFotoPreview || editForm.fotoUrl || ""} alt="Anteprima foto" />
                    <div className="ac-photo-actions">
                      {editFotoPreview ? (
                        <button
                          type="button"
                          className="ac-link-btn"
                          onClick={() =>
                            handleFotoSelect(
                              null,
                              setEditFotoFile,
                              setEditFotoPreview,
                              editFotoPreview,
                            )
                          }
                        >
                          Annulla nuova foto
                        </button>
                      ) : null}
                      {editForm.fotoUrl ? (
                        <button type="button" className="ac-link-btn" onClick={handleEditRemovePhoto}>
                          Rimuovi foto
                        </button>
                      ) : null}
                    </div>
                  </div>
                ) : null}
              </div>
            </div>

            <div className="ac-modal-actions">
              <button className="ac-secondary-btn" type="button" onClick={handleEditClose}>
                Annulla
              </button>
              <button
                className="ac-primary-btn"
                type="button"
                onClick={handleEditSave}
                disabled={editSaving}
              >
                {editSaving ? "Salvataggio..." : "Salva modifiche"}
              </button>
            </div>
          </div>
        </div>
      ) : null}

      <PdfPreviewModal
        open={pdfPreviewOpen}
        title="Anteprima PDF attrezzature cantieri"
        pdfUrl={pdfPreviewUrl}
        fileName={pdfPreviewFileName}
        hint={pdfShareHint}
        onClose={closePdfPreview}
        onShare={handleSharePDF}
        onCopyLink={handleCopyPDFText}
        onWhatsApp={handleWhatsAppPDF}
      />
    </>
  );
}
