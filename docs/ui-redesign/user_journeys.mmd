flowchart TB
  classDef step fill:#eef4ff,stroke:#3a5ea0,stroke-width:1px;
  classDef data fill:#fff8e6,stroke:#8f6500,stroke-width:1px;

  D_LAVORI["@lavori"]:::data
  D_ORDINI["@ordini"]:::data
  D_INV["@inventario"]:::data
  D_CONS["@materialiconsegnati"]:::data
  D_TMP["@rifornimenti_autisti_tmp / @segnalazioni_autisti_tmp / @controlli_mezzo_autisti / @richieste_attrezzature_autisti_tmp / @cambi_gomme_autisti_tmp"]:::data
  D_CANON["@rifornimenti / @gomme_eventi"]:::data
  D_DOC["@documenti_*"]:::data
  D_STO["@storico_eventi_operativi / @autisti_sessione_attive"]:::data
