              <NextDossierMezzoPage />
            </NextRoleGuard>
          }
        />
        <Route
          path="dossier/:targa"
          element={
            <NextRoleGuard areaId="mezzi-dossier">
              <NextDossierMezzoPage />
            </NextRoleGuard>
          }
        />
        <Route
          path="dossier/:targa/gomme"
          element={
