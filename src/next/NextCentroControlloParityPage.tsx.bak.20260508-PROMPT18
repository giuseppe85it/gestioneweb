                        >
                          <td>{i + 1}</td>
                          <td>
                            <input
                              type="checkbox"
                              className="cc-analisi-flag-checkbox"
                              checked={mezziSelected.has(m.id)}
                              onChange={() => toggleMezzoFlag(m.id)}
                              aria-label={`Flag mezzo ${m.targa}`}
                            />
                          </td>
                          <td>{m.targa}</td>
                          <td>
