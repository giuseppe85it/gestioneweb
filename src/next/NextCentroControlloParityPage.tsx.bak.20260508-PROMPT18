            if (scostamento <= -0.15) {
              return <span className="cc-analisi-tag-warn">{pctText}</span>;
            }
            return <span className="cc-analisi-tag-ok">in linea</span>;
          };

          const renderClassificaMezzi = () => {
            if (data.mezziAggregati.length === 0) {
