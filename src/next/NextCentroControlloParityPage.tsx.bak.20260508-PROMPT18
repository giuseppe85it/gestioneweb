                </p>
                <div className="cc-table-wrap">
                  <table className="cc-table cc-analisi-table">
                    <thead>
                      <tr>
                        <th>#</th>
                        <th>Flag</th>
                        <th>Targa</th>
                        <th title={tooltipSemplice}>km/L semplice ?</th>
                        <th title={tooltipPesata}>km/L pesata ?</th>
                        <th>Km tot</th>
                        <th>Litri tot</th>
                        <th>Rif.</th>
                      </tr>
                    </thead>
                    <tbody>
                      {data.mezziAggregati.map((m, i) => (
                        <tr
