              <NextMezziDossierDetailLegacyRedirect />
            </NextRoleGuard>
          }
        />
        <Route
          path="analisi-economica/:targa"
          element={
            <NextRoleGuard areaId="mezzi-dossier">
              <NextAnalisiEconomicaPage />
            </NextRoleGuard>
          }
        />
        <Route
          path="ia"
          element={
            <NextRoleGuard areaId="ia">
              <NextIntelligenzaArtificialePage />
            </NextRoleGuard>
          }
        />
        <Route
          path="ia/report"
          element={
            <NextRoleGuard areaId="ia">
              <NextInternalAiPage />
            </NextRoleGuard>
          }
        />
        <Route
          path="ia/archivista"
          element={
            <NextRoleGuard areaId="ia">
              <NextIAArchivistaPage />
            </NextRoleGuard>
          }
        />
        <Route
          path="ia/interna"
