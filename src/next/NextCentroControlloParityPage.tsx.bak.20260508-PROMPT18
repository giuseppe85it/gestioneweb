                          </td>
                          <td>
                            <strong>
                              {a.pesata !== null
                                ? formatMediaLitriKm(a.pesata)
                                : "—"}
                            </strong>
                          </td>
                          <td>{formatNumberIt(a.kmTot, 0)}</td>
                          <td>{formatNumberIt(a.litriTot, 2)}</td>
