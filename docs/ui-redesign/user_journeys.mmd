    J3C --> D_ORDINI
  end

  subgraph J4["J4 - Arrivo materiale -> inventario"]
    J4A["Dettaglio ordine"]:::step --> J4B["Segna materiale arrivato"]:::step
    J4B --> J4C["Ordini arrivati"]:::step
    J4B --> D_ORDINI
    J4B --> D_INV
  end

